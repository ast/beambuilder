        (-256.0,   96.0),
        (-128.0, -224.0),
        ( 128.0, -224.0),
        ( 256.0,    0.0),
        ( 640.0,    0.0),
    ],
    vehicle_spawn: (-512.0,  128.0),
    goal:          ( 512.0,    0.0),
)
